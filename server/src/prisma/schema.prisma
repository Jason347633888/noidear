  updatedAt      DateTime @updatedAt

  @@unique([sourceDocId, targetType, targetId, targetRoute, sectionId])
  @@index([sourceDocId])
  @@index([targetDocId])
  @@index([targetType, targetId])
  @@index([relationType])
  @@index([wikilinkTarget])
  @@map("document_references")
}

model BusinessDocumentLink {
