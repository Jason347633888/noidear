  id               String    @id @default(cuid())
  taskId           String
  task             Task      @relation(fields: [taskId], references: [id])
  templateId       String
  dataJson         Json      @default("{}")
  submitterId      String
  submitter        User      @relation("TaskRecordSubmitter", fields: [submitterId], references: [id])
  status             String    @default("pending")
  approvalInstanceId String?
  submittedAt        DateTime  @default(now())
  approvedAt         DateTime?
  approverId         String?
  approver           User?     @relation("TaskRecordApprover", fields: [approverId], references: [id])
  comment            String?
  hasDeviation     Boolean   @default(false)
  deviationCount   Int       @default(0)
  deviationReasons Json?

  @@index([taskId])
  @@index([approvalInstanceId])
  @@map("task_records")
}
