  id                  String         @id @default(cuid())
  shelf_life_study_id String
  shelf_life_study    ShelfLifeStudy @relation(fields: [shelf_life_study_id], references: [id], onDelete: Cascade)
  point_code          String
  sequence            Int
  planned_at          DateTime
  status              String    @default("pending")
  skip_reason         String?
  inspection_record_id String?
  completed_at        DateTime?
  completed_by        String?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  @@unique([shelf_life_study_id, point_code])
  @@index([shelf_life_study_id, sequence])
  @@index([status, planned_at])
  @@index([inspection_record_id])
  @@map("shelf_life_study_points")
}

// ── Phase 15 Task 4: AccessDeclaration ───────────────────────────────────────

model AccessDeclaration {
  id                  String   @id @default(cuid())
  company_id          String
  declaration_type    String
  subject_type        String
  subject_id          String?
  subject_snapshot    Json?
  declaration_content Json
  declared_by         String?
  declared_at         DateTime
  approved_by         String?
  approved_at         DateTime?
  approval_conclusion String?
  approval_opinion    String?
  evidence_file_id    String?
  status              String   @default("declared")
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt
  visitor_links       VisitorAccessDeclaration[] @relation("AccessDeclarationLinks")

  @@index([company_id, declaration_type, status])
  @@index([subject_type, subject_id])
  @@map("access_declarations")
}

// ── Phase 15 Task 5: VisitorRecord + VisitorAccessDeclaration join ────────────
model VisitorAccessDeclaration {
  visitor_record_id     String
  access_declaration_id String
  declaration_type      String
  visitor_record        VisitorRecord     @relation("VisitorRecordDeclarations", fields: [visitor_record_id], references: [id], onDelete: Cascade)
  access_declaration    AccessDeclaration @relation("AccessDeclarationLinks", fields: [access_declaration_id], references: [id], onDelete: Cascade)

  @@id([visitor_record_id, access_declaration_id])
  @@index([visitor_record_id])
  @@index([access_declaration_id])
  @@map("visitor_access_declarations")
}
