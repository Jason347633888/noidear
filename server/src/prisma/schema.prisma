  filePath        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Task 9: bounded trace-context snapshot (immutable trace result)
  rootObjectType   String?
  rootObjectId     String?
  snapshotData     Json?
  fileId           String?
  snapshotPurpose  String  @default("evidence_export") // evidence_export | preview
  readinessStatus  String  @default("complete") // complete | incomplete
  readinessReasons Json?

  productRecalls       ProductRecall[] @relation("ProductRecallTraceabilitySnapshot")
  lockedByProductRecalls ProductRecall[] @relation("ProductRecallLockedSnapshot")

  @@index([company_id])
  @@map("traceability_snapshots")
}

