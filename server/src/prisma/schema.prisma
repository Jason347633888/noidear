// ========================================
// RD-001: 产品研发流程模块
// ========================================

enum ProcessStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  REJECTED
}

enum ProcessStepStatus {
  PENDING
  IN_PROGRESS
  SUBMITTED
  APPROVED
  REJECTED
}

model ProcessTemplate {
  id        String   @id @default(cuid())
  name      String
  steps     Json     // 7步流程配置（CX-26）
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  instances ProcessInstance[]

  @@map("process_templates")
}

model ProcessInstance {
  id          String        @id @default(cuid())
  templateId  String
  template    ProcessTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  productName String        @default("")
  currentStep Int           @default(1)
  status      ProcessStatus @default(DRAFT)
  createdById String
  createdBy   User          @relation("ProcessCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  stepData ProcessStepData[]
  productId   String?
  product     Product?              @relation("ProcessProduct", fields: [productId], references: [id], onDelete: SetNull)
  approvals   ProcessStepApproval[]

  @@index([createdById])
  @@index([status])
  @@index([productId])
  @@map("process_instances")
}

model ProcessStepData {
  id              String            @id @default(cuid())
  instanceId      String
  instance        ProcessInstance   @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  stepNumber      Int
  data            Json              @default("{}")
  status             ProcessStepStatus @default(PENDING)
  approvalInstanceId String?
  submittedById      String?
  submittedBy     User?             @relation("StepSubmitter", fields: [submittedById], references: [id], onDelete: SetNull)
  submittedAt     DateTime?
  approvedById    String?
  approvedBy      User?             @relation("StepApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt      DateTime?
  approvalComment String?           @db.Text
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([instanceId, stepNumber])
  @@index([instanceId])
  @@index([approvalInstanceId])
  @@map("process_step_data")
}

model ProcessStepApproval {
  id          String          @id @default(cuid())
  instanceId  String
  instance    ProcessInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  stepNumber  Int
  approverId  String?
  approver    User?           @relation("StepApprovalUser", fields: [approverId], references: [id], onDelete: SetNull)
  department  String
  role        String
  status      String          @default("PENDING")
  comment     String?
  signedAt    DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([instanceId, stepNumber, role])
  @@index([instanceId, stepNumber])
  @@index([role, status])
  @@index([approverId, status])
  @@map("process_step_approvals")
}

// P2: 跨文档引用表（BR-305/306）
model DocumentReference {
  id          String   @id @default(cuid())
  sourceDocId String
  sourceDoc   Document @relation("SourceRefs", fields: [sourceDocId], references: [id], onDelete: Cascade)

  targetDocId String?
