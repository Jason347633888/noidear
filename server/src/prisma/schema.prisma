// ─── 质量合规 ─────────────────────────────────────

model NonConformance {
  id               String    @id @default(cuid())
  company_id       String
  nc_no            String
  source_type      String // 'material_batch'|'production_batch'|'product'|'inspection_record'|'sanitizer_concentration_check'|'cleaning_record'|'calibration_record'|'maintenance_record'|'metal_detection_log'|'laundry_work_record'
  source_id        String
  source_item_id   String? // 来源子项 id；具体子表由 source_type 决定；无数据库外键，由 service 校验
  nc_type          String?
  description      String
  qty              Decimal?  @db.Decimal(14, 4)
  unit             String?
  discovered_at    DateTime
  discovered_by    String? // 发现人姓名（旧 text 字段，保留兼容）
  discoveredById   String? // 发现人 FK（Task 46 新增）
  discoveredByUser User?     @relation("NonConformanceDiscoverer", fields: [discoveredById], references: [id], onDelete: SetNull)
  disposition      String? // 'rework'|'destroy'|'concession'|'return'
  disposition_by   String?
  disposition_at   DateTime?
  status           String    @default("open") // 'open'|'dispositioned'|'closed'
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  rework_records ReworkRecord[]

  @@unique([company_id, nc_no])
  @@index([company_id, status])
  @@index([company_id, source_type, source_id, source_item_id])
  @@index([discoveredById])
}

model CorrectiveAction {
  id                 String    @id @default(cuid())
  company_id         String
