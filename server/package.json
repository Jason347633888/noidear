{
  "name": "noidear-server",
  "version": "1.0.0",
  "description": "Document Management System Backend",
  "scripts": {
    "build": "nest build",
    "build:seed": "tsc --noCheck",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "bash scripts/run-e2e.sh",
    "prisma:generate": "prisma generate --schema=src/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=src/prisma/schema.prisma",
    "prisma:seed:baseline": "ts-node src/prisma/seed-baseline.ts",
    "prisma:seed:demo": "ts-node src/prisma/seed-demo.ts",
    "prisma:seed": "npm run prisma:seed:baseline",
    "prisma:seed-org": "ts-node src/prisma/seed-org.ts",
    "prisma:seed-dev": "ts-node src/prisma/seed-dev.ts",
    "prisma:reset": "prisma db push --force-reset --schema=src/prisma/schema.prisma && npm run prisma:seed:baseline",
    "docker:init": "prisma db push --schema=src/prisma/schema.prisma && npm run prisma:seed:baseline",
    "seed:templates": "npx ts-node --compiler-options '{\"module\":\"commonjs\"}' scripts/seed-templates.ts",
    "documents:import-vault": "npx ts-node --compiler-options '{\"module\":\"commonjs\"}' scripts/import-vault-system-documents.ts",
    "model-landing:generate": "tsx scripts/generate-model-landing-artifacts.ts",
    "model-landing:verify": "tsx scripts/verify-model-landing-artifacts.ts",
    "traceability:test": "jest traceability-query.service.spec.ts traceability-balance.service.spec.ts traceability-linkage.service.spec.ts traceability-export.service.spec.ts --runInBand",
    "traceability:contract:test": "jest traceability-contract.mapper.spec.ts --runInBand",
    "traceability:e2e": "bash scripts/run-e2e.sh traceability-contract.e2e-spec.ts traceability-query.e2e-spec.ts",
    "traceability:verify": "npm run traceability:test && npm run traceability:contract:test && npm run traceability:e2e",
    "recall:migrate-records": "ts-node scripts/migrate-product-recall-records.ts",
    "seed:e2e": "ts-node src/prisma/seed-e2e.ts"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^10.0.0",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^7.1.0",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^5.7.0",
    "@types/ioredis": "^4.28.10",
    "@types/pdfkit": "^0.17.5",
    "@types/pdfmake": "^0.3.1",
    "axios": "^1.15.1",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.0",
    "class-validator": "^0.14.0",
    "cron-parser": "^5.5.0",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "glob": "^13.0.6",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.3",
    "jsonwebtoken": "^9.0.0",
    "jszip": "^3.10.1",
    "ldapjs": "^3.0.7",
    "minio": "^8.0.6",
    "nanoid": "^3.3.11",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.17.2",
    "pdfmake": "^0.3.4",
    "reflect-metadata": "^0.1.13",
    "rxjs": "7.8.1",
    "safe-regex": "^2.1.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.4.22",
    "@types/bcrypt": "^5.0.0",
    "@types/express": "^4.17.17",
    "@types/helmet": "^0.0.48",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/ldapjs": "^3.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.19.30",
    "@types/passport-jwt": "^4.0.1",
    "@types/safe-regex": "^1.1.6",
    "@types/sharp": "^0.31.1",
    "@types/supertest": "^6.0.3",
    "jest": "^30.2.0",
    "prisma": "^5.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20 <23",
    "npm": ">=10"
  }
}
