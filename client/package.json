    "@vue/shared": "^3.4.0",
    "axios": "^1.6.0",
    "dayjs": "^1.11.0",
    "echarts": "^5.6.0",
    "echarts-wordcloud": "^2.1.0",
    "element-plus": "^2.5.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "markdown-it": "^14.1.1",
    "pinia": "^2.1.0",
    "sortablejs": "^1.15.6",
    "vue": "^3.4.0",
    "vue-router": "^4.0.0"
  },
  "devDependencies": {
    "@element-plus/icons-vue": "^2.3.0",
    "@playwright/test": "^1.58.2",
